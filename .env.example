# Optional. Point a fork at your own Supabase project without editing source.
# If these are unset, src/persistence.js falls back to the public demo project,
# so a fresh clone runs with no configuration at all.
#
# Copy to .env and fill in. Only the PUBLISHABLE (anon) key belongs here — it is
# meant to be visible in client code and is protected by row-level security.
# Never put a service-role key in this file or anywhere in the repo.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your_key_here
